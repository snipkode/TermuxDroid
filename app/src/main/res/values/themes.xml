<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme - Dark theme for streaming -->
    <style name="Theme.Drachin" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent_variant</item>
        <item name="colorOnSecondary">@color/on_primary</item>

        <!-- Background and surface colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/background</item>
    </style>

    <!-- Button style -->
    <style name="Theme.Drachin.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Card style -->
    <style name="Theme.Drachin.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>
</resources>
